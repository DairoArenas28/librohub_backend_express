                "comments"
              ],
              "variable": [
                {
                  "key": "bookId",
                  "value": "1",
                  "description": "ID del libro (UUID)"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Excelente libro, muy recomendado.\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {

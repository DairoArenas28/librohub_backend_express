    {
      "name": "Users",
      "description": "Gestion de usuarios.\n\nAccesible para cualquier usuario autenticado: /me, avatar\nRequiere rol admin: GET /, POST /, PUT /:id, DELETE /:id",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
